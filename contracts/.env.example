# RPC URLs
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC_URL=
MAINNET_RPC_URL=

# Explorer verification
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=

# Required deployment addresses
S_MAX=1000000000000000000000000000
COMMUNITY_PROGRAM_OWNER=
TREASURY_ADDRESS=
TEAM_BENEFICIARY=
INVESTOR_BENEFICIARY=
LIQUIDITY_ADDRESS=
OWNER_ADDRESS=

# Optional deployment signer.
# Leave unset to use the currently configured Foundry broadcaster.
# Never commit a real private key.
DEPLOYER_PRIVATE_KEY=

# Protocol parameters
VERIFIER_MINIMUM_STAKE=1000000000000000000000
VERIFIER_UNBONDING_DELAY=1296000
SOLVER_BOND=10000000000000000000
VERIFIER_REWARD_BPS=200
TREASURY_BURN_BPS=2000
DEFAULT_SOLVER_ACCESS_REWARD_BPS=100
SOLVER_ROYALTY_BPS=5000

# Required only for Ethereum mainnet or Arbitrum One deployments.
PRODUCTION_DEPLOYMENT_APPROVED=false
